Options -Indexes

# ── Security: block direct access to source and config files ─────────────
<FilesMatch "^(config\.php|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

# ── URL routing: send all requests through index.php ─────────────────────
RewriteEngine On

# Block direct access to source directories
RewriteRule ^(src|views|migrations|lang)(/|$) - [F,L]

# Pass through real files and directories (assets, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to the entry point
RewriteRule ^ index.php [QSA,L]
